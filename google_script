  var isUnclearDeadline = false;
  if (result.applicationDeadline) {
    var deadline = result.applicationDeadline.toLowerCase().trim();
    
    // Check for explicit unclear indicators
    var explicitUnclear = (
      deadline === 'no deadline specified' ||
      deadline === 'unclear' ||
      deadline.includes('to be confirmed') ||
      deadline.includes('tbc') ||
      deadline.includes('not specified') ||
      deadline.includes('not explicitly stated') ||
      deadline.includes('rolling') ||
      deadline.includes('ongoing') ||
      deadline === 'n/a'
    );
    
