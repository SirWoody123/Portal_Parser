      isVagueText = (
        deadline.includes('apply') ||
        deadline.includes('contact') ||
        deadline.includes('email') ||
        deadline.includes('when') ||
        deadline.includes('next') ||
        deadline.includes('soon') ||
        deadline.includes('later') ||
        deadline.includes('call') ||
        deadline.includes('website') ||
        deadline.includes('visit') ||
        deadline.length > 50 // Very long text is likely descriptive rather than a date
      );
    }
    
    isUnclearDeadline = explicitUnclear || isVagueText;
  } else {
    isUnclearDeadline = true; // No deadline at all
  }

  if (isUnclearDeadline) {
    if (result.title && result.title.trim() !== '') {
      result.title = result.title + ' [Unclear Deadline]';
    } else {
      result.title = 'Opportunity [Unclear Deadline]';
    }
    Logger.log('🔍 TEXT PARSER: Added "Unclear Deadline" to title due to unclear/missing deadline');
  }

  Logger.log('🔍 TEXT PARSER (Google Script): Final parsed result: ' + JSON.stringify(result, null, 2));
  return result;
}

